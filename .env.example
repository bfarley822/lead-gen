# LLM Provider: ollama (default) or openai
LLM_PROVIDER=ollama
# Event collection: auto follows LLM_PROVIDER (openai → OpenAI web search, ollama → SearXNG). Override: searxng | openai
# COLLECTOR_SEARCH_PROVIDER=auto
# Responses API model for built-in web_search (when COLLECTOR_SEARCH_PROVIDER=openai or auto+openai LLM)
# OPENAI_RESPONSES_SEARCH_MODEL=gpt-4o-mini
# OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium
# OPENAI_COLLECTOR_CONCURRENCY=4
# OPENAI_COLLECTOR_BATCH_DELAY_MS=600
# OPENAI_COLLECTOR_TIMEOUT_MS=120000

# Ollama local inference
# Install Ollama: https://ollama.com
# Pull models: ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_DEDUP_MODEL=qwen2.5:14b
# Per-stage model overrides (optional, fall back to OLLAMA_MODEL)
# Use larger models on research/scoring for better quality:
# OLLAMA_TRIAGE_MODEL=qwen2.5:14b
# OLLAMA_RESEARCH_MODEL=qwen2.5:32b
# OLLAMA_SCORING_MODEL=qwen2.5:32b

# OpenAI (set LLM_PROVIDER=openai to use)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Per-stage overrides (optional, fall back to OPENAI_MODEL):
# OPENAI_DEDUP_MODEL=gpt-4o-mini
# OPENAI_TRIAGE_MODEL=gpt-4o-mini
# OPENAI_RESEARCH_MODEL=gpt-4o
# OPENAI_SCORING_MODEL=gpt-4o

# SearXNG — local Docker instance (unlimited, free, no API key)
# Start with: docker compose -f docker/docker-compose.yml up -d
SEARXNG_BASE_URL=http://localhost:8888
# Optional SearXNG JSON API tuning (improves raw result quality)
# SEARXNG_LANGUAGE=en
# Prefer recent index; use empty or "off" to disable: SEARXNG_TIME_RANGE=year
# SEARXNG_TIME_RANGE=year
# SEARXNG_CATEGORIES=general
# Limit engines if one backend is noisy: SEARXNG_ENGINES=google,bing

# Search configuration
SEARCH_LOCATION="La Quinta, CA"
# Optional: full store address for franchise-specific context in LLM prompts
STORE_ADDRESS="79795 US Highway 111, La Quinta, CA 92253"
# Optional multi-location mode (semicolon-separated):
# SEARCH_CITIES="Provo, UT;Lehi, UT;Orem, UT;Salt Lake City, UT"
SEARCH_CITIES=
CITY_CONCURRENCY=4
SEARCH_RADIUS_MILES=25
# Radius (miles) to assign an event to a store — only stores within this distance get the event
ASSIGNMENT_RADIUS_MILES=10
# Radius (miles) for broader area search — nearby franchise cities included in SearXNG queries and cross-assign
BROAD_SEARCH_RADIUS_MILES=10
SEARCH_KEYWORDS="conference, expos, wedding, meetups, networking, community, corporate, catering, fair, festival, market"
MAX_EVENTS_FOR_SCORING=20
MIN_RELEVANCE_SCORE=40
QUALIFIER_MIN_SIGNAL_SCORE=2
QUALIFIER_MAX_CANDIDATES=20
WRITE_STAGE_ARTIFACTS=true

# Optional: comma-separated RSS/iCal feed URLs
FEED_URLS=

# ── Web Dashboard database ──
# Default: bundled SQLite at web/data/lead-gen.db (commit it; Vercel reads it read-only — no Turso).
# After running the CLI: cd web && npm run copy-db — then git add web/data/lead-gen.db
# Optional: remote Turso instead of the file (omit to use bundled DB)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token
# Optional absolute path to SQLite when not using default web/data/lead-gen.db
# BUNDLED_DB_PATH=
# API cache + client polling (reduce load if you use Turso again)
# DASHBOARD_CACHE_SECONDS=60
# RUNS_LIST_CACHE_SECONDS=15
# NEXT_PUBLIC_DASHBOARD_POLL_MS=30000
# NEXT_PUBLIC_LIVE_LOG_POLL_MS=3000
